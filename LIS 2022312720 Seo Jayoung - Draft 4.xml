<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================
  XML 인스턴스 레코드 — 한국 스킨케어 제품 스키마
  Draft 4 | 서재영 (2022312720)

  총 3개의 제품 레코드 포함:
    1. 라운드랩 독도 토너 (Object #1)
    2. COSRX 달팽이 뮤신 에센스 (Object #2)
    3. 빌리프 조선미녀 선크림 (Object #4)

  유효성 검사 대상: skincare_schema.xsd
  ============================================================
-->

<!--
  [네임스페이스 선언 방식에 대한 설계 의도]
  스키마의 targetNamespace를 기본 네임스페이스(xmlns)로 선언하여
  모든 skc: 요소에 접두사 없이 바로 쓸 수 있도록 했다.
  dc: 접두사는 Dublin Core 요소(dc:title, dc:description)에만 사용한다.
  xsi:schemaLocation으로 네임스페이스 URI와 XSD 파일 경로를 연결한다.
-->
<catalog
  xmlns="https://example.org/skincare#"
  xmlns:dc="http://purl.org/dc/elements/1.1/"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="https://jayoung-seo3.github.io/skincare-schema/">


  <!-- ============================================================
       레코드 1 — 라운드랩 독도 토너 (Object #1)
       민감성·건성 피부를 위한 수분 토너.
       무향, 무알코올, EWG 인증 제품.
       ============================================================ -->
  <skincareProduct productID="product001">

    <!-- dc:title: 라벨에 표기된 공식 제품명 -->
    <dc:title>Round Lab Dokdo Toner</dc:title>

    <!-- brand: 코퍼스 브랜드 목록 기준 -->
    <brand>Round Lab</brand>

    <!-- productCategory: 한국 루틴 내 주요 카테고리 -->
    <productCategory>Toner / Softener</productCategory>

    <!-- targetSkinTypes: 건성·민감성·정상 피부에 모두 적합하므로 세 값을 기재 -->
    <targetSkinTypes>
      <targetSkinType>Dry</targetSkinType>
      <targetSkinType>Sensitive</targetSkinType>
      <targetSkinType>Normal</targetSkinType>
    </targetSkinTypes>

    <!-- targetSkinConcerns: 이 제품이 다루는 주요 피부 고민 3가지 -->
    <targetSkinConcerns>
      <targetSkinConcern>Hydration</targetSkinConcern>
      <targetSkinConcern>Barrier repair</targetSkinConcern>
      <targetSkinConcern>Soothing / Redness relief</targetSkinConcern>
    </targetSkinConcerns>

    <!-- keyIngredients: INCI명과 기능적 역할을 포함한 주요 활성 성분 3가지 -->
    <keyIngredients>
      <keyIngredient>
        <inci>Dokdo Sea Water</inci>
        <role>Humectant</role>
      </keyIngredient>
      <keyIngredient>
        <inci>Panthenol</inci>
        <role>Emollient</role>
      </keyIngredient>
      <keyIngredient>
        <inci>Sodium Hyaluronate</inci>
        <role>Humectant</role>
      </keyIngredient>
    </keyIngredients>

    <!-- avoidIngredients: 무향·무알코올 제품이므로 기피 성분 없음.
         Draft 3 지침에 따라 요소 자체를 생략하지 않고
         자식 없는 빈 래퍼로 두어 명시적으로 기피 성분이
         없음을 표현한다. -->
    <avoidIngredients/>

    <!-- textureType: 워터리 질감 -->
    <textureType>Watery</textureType>

    <!-- functionalClaims: 저자극, 무향, EWG 인증 3가지 -->
    <functionalClaims>
      <functionalClaim>
        <claimType>Hypoallergenic</claimType>
        <claimValue>Hypoallergenic</claimValue>
      </functionalClaim>
      <functionalClaim>
        <claimType>Fragrance-free</claimType>
        <claimValue>Fragrance-free</claimValue>
      </functionalClaim>
      <functionalClaim>
        <claimType>EWG verified</claimType>
        <claimValue>EWG verified</claimValue>
      </functionalClaim>
    </functionalClaims>

    <!-- routineStep: 한국 10단계 루틴의 4단계(토너) -->
    <routineStep>Step 4: Toner</routineStep>

    <!-- usageContexts: 연중 사용 가능, 건조 기후 특히 적합, AM·PM 모두 사용 -->
    <usageContexts>
      <usageContext dimension="Season">Year-round</usageContext>
      <usageContext dimension="Climate">Dry</usageContext>
      <usageContext dimension="Time of day">Both</usageContext>
    </usageContexts>

    <!-- targetAgeRanges: 20대·30대 주요 타겟, 전 연령대 사용 가능 -->
    <targetAgeRanges>
      <targetAgeRange>20s</targetAgeRange>
      <targetAgeRange>30s</targetAgeRange>
      <targetAgeRange>All ages</targetAgeRange>
    </targetAgeRanges>

    <!-- priceSpecification: 18,000원 -->
    <priceSpecification>
      <hasCurrencyValue>18000</hasCurrencyValue>
      <hasCurrency>KRW</hasCurrency>
    </priceSpecification>

    <!-- dc:description: 구조화 요소로 담기 어려운 세부 정보 -->
    <dc:description>독도 심층수를 주성분으로 한 수분 토너. 무향·무알코올 클린 포뮬라로 민감하거나 예민한 피부에 적합하다.</dc:description>

    <!-- compatibleProducts: COSRX 달팽이 뮤신 에센스를 이 제품 이후에 사용 -->
    <compatibleProducts>
      <compatibleProduct>
        <productRef>product002</productRef>
        <position>after</position>
      </compatibleProduct>
    </compatibleProducts>

  </skincareProduct>


  <!-- ============================================================
       레코드 2 — COSRX 달팽이 뮤신 96 파워 에센스 (Object #2)
       피부 재생 및 보습 기능성 에센스.
       달팽이 분비물 여과물 96% 함유.
       ============================================================ -->
  <skincareProduct productID="product002">

    <dc:title>COSRX Advanced Snail 96 Mucin Power Essence</dc:title>

    <brand>COSRX</brand>

    <productCategory>Essence</productCategory>

    <targetSkinTypes>
      <targetSkinType>Dry</targetSkinType>
      <targetSkinType>Normal</targetSkinType>
      <targetSkinType>Combination</targetSkinType>
      <targetSkinType>Sensitive</targetSkinType>
    </targetSkinTypes>

    <targetSkinConcerns>
      <targetSkinConcern>Hydration</targetSkinConcern>
      <targetSkinConcern>Barrier repair</targetSkinConcern>
      <targetSkinConcern>Soothing / Redness relief</targetSkinConcern>
    </targetSkinConcerns>

    <!-- keyIngredients: 달팽이 분비물 여과물이 96% 함유되어 있어 농도 명시 -->
    <keyIngredients>
      <keyIngredient>
        <inci>Snail Secretion Filtrate</inci>
        <role>Emollient</role>
        <concentration unit="percent">96</concentration>
      </keyIngredient>
      <keyIngredient>
        <inci>Sodium Hyaluronate</inci>
        <role>Humectant</role>
      </keyIngredient>
    </keyIngredients>

    <avoidIngredients/>

    <textureType>Serum (viscous)</textureType>

    <functionalClaims>
      <functionalClaim>
        <claimType>Non-comedogenic</claimType>
        <claimValue>Non-comedogenic</claimValue>
      </functionalClaim>
    </functionalClaims>

    <!-- routineStep: 5단계(에센스) — 토너 이후, 세럼 이전에 사용 -->
    <routineStep>Step 5: Essence</routineStep>

    <usageContexts>
      <usageContext dimension="Season">Year-round</usageContext>
      <usageContext dimension="Time of day">Both</usageContext>
    </usageContexts>

    <targetAgeRanges>
      <targetAgeRange>20s</targetAgeRange>
      <targetAgeRange>30s</targetAgeRange>
      <targetAgeRange>40s+</targetAgeRange>
    </targetAgeRanges>

    <priceSpecification>
      <hasCurrencyValue>25000</hasCurrencyValue>
      <hasCurrency>KRW</hasCurrency>
    </priceSpecification>

    <dc:description>달팽이 분비물 여과물 96%를 함유한 에센스. 빠르게 흡수되는 점성 텍스처로 수분 공급과 피부 재생에 효과적이며, 민감성 피부를 포함한 대부분의 피부 타입에 잘 맞는다.</dc:description>

    <!-- compatibleProducts: 라운드랩 독도 토너 이후에 사용 -->
    <compatibleProducts>
      <compatibleProduct>
        <productRef>product001</productRef>
        <position>before</position>
      </compatibleProduct>
    </compatibleProducts>

  </skincareProduct>


  <!-- ============================================================
       레코드 3 — 빌리프 조선미녀 선크림 (Object #4)
       미백 성분이 함유된 하이브리드 미네랄-화학적 자외선 차단제.
       SPF 50+ PA++++ 및 기능성화장품(자외선차단) 인증 보유.
       ============================================================ -->
  <skincareProduct productID="product003">

    <dc:title>Beauty of Joseon Relief Sun: Rice + Probiotics</dc:title>

    <brand>Beauty of Joseon</brand>

    <productCategory>Sunscreen</productCategory>

    <targetSkinTypes>
      <targetSkinType>Dry</targetSkinType>
      <targetSkinType>Sensitive</targetSkinType>
      <targetSkinType>Normal</targetSkinType>
      <targetSkinType>All skin types</targetSkinType>
    </targetSkinTypes>

    <targetSkinConcerns>
      <targetSkinConcern>Sun protection</targetSkinConcern>
      <targetSkinConcern>Brightening</targetSkinConcern>
      <targetSkinConcern>Soothing / Redness relief</targetSkinConcern>
    </targetSkinConcerns>

    <keyIngredients>
      <keyIngredient>
        <inci>Niacinamide</inci>
        <role>Brightening agent</role>
      </keyIngredient>
      <keyIngredient>
        <inci>Rice Bran Extract</inci>
        <role>Antioxidant</role>
      </keyIngredient>
      <keyIngredient>
        <inci>Lactobacillus Ferment</inci>
        <role>Anti-inflammatory</role>
      </keyIngredient>
    </keyIngredients>

    <!-- avoidIngredients: 물리적/하이브리드 필터 사용으로 옥시벤존 미함유.
         기피 성분이 없음을 명시적으로 표현하기 위해 빈 래퍼로 둔다. -->
    <avoidIngredients/>

    <textureType>Lightweight lotion</textureType>

    <!-- functionalClaims: 선크림 레코드이므로 SPF·PA는 사실상 필수.
         기능성화장품 분류 및 무향 인증도 함께 기재한다. -->
    <functionalClaims>
      <functionalClaim>
        <claimType>SPF</claimType>
        <claimValue>50+</claimValue>
      </functionalClaim>
      <functionalClaim>
        <claimType>PA</claimType>
        <claimValue>++++</claimValue>
      </functionalClaim>
      <functionalClaim>
        <claimType>기능성화장품</claimType>
        <claimValue>자외선차단</claimValue>
      </functionalClaim>
      <functionalClaim>
        <claimType>Fragrance-free</claimType>
        <claimValue>Fragrance-free</claimValue>
      </functionalClaim>
    </functionalClaims>

    <!-- routineStep: AM 루틴의 마지막 단계(10단계: 선크림) -->
    <routineStep>Step 10: Sunscreen (AM) / Sleeping pack (PM)</routineStep>

    <!-- usageContexts: 여름, 고온·고습 기후, AM 루틴, 야외 활동 특히 적합 -->
    <usageContexts>
      <usageContext dimension="Season">Summer</usageContext>
      <usageContext dimension="Climate">Hot</usageContext>
      <usageContext dimension="Climate">Humid</usageContext>
      <usageContext dimension="Time of day">AM routine</usageContext>
      <usageContext dimension="Setting">Outdoor</usageContext>
    </usageContexts>

    <targetAgeRanges>
      <targetAgeRange>20s</targetAgeRange>
      <targetAgeRange>30s</targetAgeRange>
      <targetAgeRange>40s+</targetAgeRange>
    </targetAgeRanges>

    <priceSpecification>
      <hasCurrencyValue>14000</hasCurrencyValue>
      <hasCurrency>KRW</hasCurrency>
    </priceSpecification>

    <dc:description>나이아신아마이드와 쌀겨 추출물이 함유된 하이브리드 선크림. 가볍고 번들거림 없는 텍스처로 자외선 차단과 함께 미백 효과를 제공하여 AM 루틴 마지막 단계 제품으로 널리 사용된다.</dc:description>

    <!-- compatibleProducts: AM 루틴에서 독도 토너(product001) 이후에 사용 -->
    <compatibleProducts>
      <compatibleProduct>
        <productRef>product001</productRef>
        <position>after</position>
      </compatibleProduct>
    </compatibleProducts>

  </skincareProduct>

</catalog>
